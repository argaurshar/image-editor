# Copy this file to ".env.local" and fill in your own values.
# .env.local is gitignored and will never be committed.

# Required: your Google Gemini API key (https://aistudio.google.com/apikey)
GEMINI_API_KEY=

# Optional: override the models used.
# Vision model that turns the photo into the structured JSON table.
ANALYZE_MODEL=gemini-2.5-flash
# "Nano Banana Pro" image generation/editing model.
IMAGE_MODEL=gemini-3-pro-image-preview
